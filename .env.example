# Environment Variables for MicroLeague Listener
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080

# Database Configuration
DATABASE_URL="your_database_connection_string_here"

# Contract Addresses
PRESALE_CONTRACT=0x0000000000000000000000000000000000000000

# Cloudinary Configuration (for PDF storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# RPC Provider Pool (for blockchain interaction)
RPC_URL_PRIMARY=https://your-primary-rpc-url
RPC_URL_SECONDARY=https://your-secondary-rpc-url
RPC_URL_TERTIARY=https://your-tertiary-rpc-url

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USERNAME=default

# Event Queue Configuration
EVENT_MAX_RETRIES=5
EVENT_RETRY_DELAY=2000
EVENT_WORKER_CONCURRENCY=10
EVENT_RATE_LIMIT_MAX=100
EVENT_RATE_LIMIT_DURATION=1000

# Blockchain Configuration
CONFIRMATION_BLOCKS=3
POLLING_INTERVAL=15000
BATCH_SIZE=1000

# Monitoring
ENABLE_METRICS=true

# Mailgun Configuration (for email sending)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here
MAILGUN_FROM=your_from_email@yourdomain.com
MAILGUN_BASE_URL=https://api.mailgun.net/v3

# PDF Configuration
PDF_OUTPUT_DIR=./pdfs

# Email Settings
SAFT_EMAIL_ENABLED=true