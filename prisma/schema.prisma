// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PresaleTxType {
  Blockchain
  Wert
  Crypto_Payment
  Bank_Transfer
  Other_Cryptos
  Card_Payment
  Buy
  Claim
}

enum BuyerStatus {
  Active
  Inactive
  All
}

model User {
  id                              String      @id @default(cuid())
  userId                          String      @unique
  walletAddress                   String?     @unique
  email                          String?
  firstName                      String?
  lastName                       String?
  phone                          String?
  profileImage                   String?
  country                        String?
  username                       String?
  fullName                       String?
  
  // Presale related fields
  tokensPurchased                 Float       @default(0)
  amountSpent                     Float       @default(0)
  claimed                         Float       @default(0)
  unclaimed                       Float       @default(0)
  joinDate                        DateTime?
  lastActivity                    DateTime?
  status                          BuyerStatus @default(Active)
  
  // Referral fields
  referredById                    String?
  referredBy                      User?       @relation("UserReferrals", fields: [referredById], references: [id])
  referrals                       User[]      @relation("UserReferrals")
  referralEarnings                Float       @default(0)
  
  // Settings
  notificationsEnabled            Boolean     @default(true)
  isAdmin                         Boolean     @default(false)
  
  // KYC fields
  kycStatus                       String      @default("pending")
  veriffSessionId                 String?
  kycVerifiedAt                   DateTime?
  kycDeclinedReason               String?
  
  // Reputation fields
  reputationScore                 Int         @default(100)
  reputationTier                  String      @default("Good")
  reputationUpdatedAt             DateTime?
  poolContributionScore           Int         @default(0)
  kycScore                        Int         @default(0)
  stakingScore                    Int         @default(0)
  externalCreditScore             Int         @default(0)
  
  // Staking fields
  stakedAmount                    Float       @default(0)
  stakingStartDate                DateTime?
  externalCreditScoreValue        Int?
  externalCreditScoreUpdatedAt    DateTime?
  
  // Relations
  presaleTxs                      PresaleTxs[]
  
  createdAt                       DateTime    @default(now())
  updatedAt                       DateTime    @updatedAt
  
  @@map("users")
}

model PresaleTxs {
  id            String        @id @default(cuid())
  txHash        String        @unique
  contract      String
  address       String
  email         String?
  tokenAddress  String
  type          PresaleTxType @default(Crypto_Payment)
  amount        Float
  stage         Int
  tokens        Float
  timestamp     Int
  usdAmount     Float
  quote         String
  typeformId    String?
  
  // Relations
  user          User?         @relation(fields: [address], references: [walletAddress])
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@map("presale_txs")
}

model ListenerState {
  id            String    @id @default(cuid())
  contract      String
  blockNumber   Int
  hash          String
  logIndex      Int
  processedAt   DateTime
  eventId       String    @unique
  type          String
  eventName     String
  blockHash     String
  reorged       Boolean   @default(false)
  reorgedAt     DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("listener_state")
}

model FailedEvent {
  id            String    @id @default(cuid())
  eventId       String    @unique
  contract      String
  eventName     String
  blockNumber   Int
  transactionHash String
  logIndex      Int
  error         String
  retryCount    Int       @default(0)
  lastRetryAt   DateTime?
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("failed_events")
}

model Admin {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  address     String    @unique
  superAdmin  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("admins")
}

enum BankTransferStatus {
  Pending
  Verified
  Rejected
}

model BankTransfer {
  id              String              @id @default(cuid())
  transferId      String              @unique // BT-2025-001 format
  walletAddress   String
  amount          Float
  senderName      String
  bankName        String
  transactionRef  String
  paymentRef      String
  submittedDate   DateTime
  status          BankTransferStatus  @default(Pending)
  proofUrl        String
  notes           String              @default("")
  verificationNote String?
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@map("bank_transfers")
}