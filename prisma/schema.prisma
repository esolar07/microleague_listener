// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //   output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SportType {
  basketball
  baseball
  football
}

model MatchupOutcome {
  id             Int             @id
  name           String          @unique
  description    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  seasonMatchups SeasonMatchup[]

  @@map("matchup_outcomes")
}

model Sports {
  id            Int             @id @default(autoincrement())
  name          SportType       @unique
  MatchUp       MatchUp[]
  ManagedSeason ManagedSeason[]

  @@map("sports")
}

model MatchUp {
  id                  Int                  @id @default(autoincrement())
  sportId             Int
  sport               Sports               @relation(fields: [sportId], references: [id])
  homeTeamSeason      String
  homeTeamName        String
  awayTeamSeason      String
  awayTeamName        String
  matchUpResultId     Int?                 @unique
  matchUpResult       MatchUpResult?       @relation(fields: [matchUpResultId], references: [id], onDelete: SetNull)
  eraComparisonId     Int?
  eraComparison       EraComparison?       @relation(fields: [eraComparisonId], references: [id])
  slug                String?              @unique
  ruleSet             String?
  preview             Json?
  simulationStatus    String               @default("pending")
  userId              String?
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  picks               UserPick[]
  comments            Comment[]
  followedSimulations FollowedSimulation[]
  tournamentMatchup   TournamentMatchup?

  @@index([sportId])
  @@index([matchUpResultId])
  @@index([eraComparisonId])
  @@index([userId])
  @@map("match_ups")
}

model MatchUpResult {
  id                   Int                    @id @default(autoincrement())
  simulation           Json
  sourceId             Int                    @default(1)
  source               MatchupSource          @relation(fields: [sourceId], references: [id])
  slug                 String?                @unique
  seoTitle             String?
  seoDescription       String?
  seoKeywords          String?
  seoContent           String?
  jsonLd               Json?
  robots               String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  matchupResultArticle MatchupResultArticle[]
  seasonMatchup        SeasonMatchup?
  matchUp              MatchUp?
  tournamentMatchup    TournamentMatchup?
  followedSimulations  FollowedSimulation[]

  @@index([sourceId])
  @@map("match_up_results")
}

model MatchupResultArticle {
  id              Int           @id @default(autoincrement())
  matchupResultId Int
  matchUpResult   MatchUpResult @relation(fields: [matchupResultId], references: [id], onDelete: Cascade)
  matchupArticle  Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([matchupResultId])
  @@map("matchup_result_articles")
}

model EraComparison {
  id             Int             @id @default(autoincrement())
  sport          SportType
  era1           String
  era2           String
  comparisonData Json
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  managedSeasons ManagedSeason[]
  matchUps       MatchUp[]

  @@unique([sport, era1, era2])
  @@index([sport])
  @@index([era1, era2])
  @@map("era_comparisons")
}

model ManagedSeason {
  id              Int             @id @default(autoincrement())
  sportId         Int
  sport           Sports          @relation(fields: [sportId], references: [id])
  teamName        String
  teamSeason      String
  playingSeason   String
  seasonName      String
  seasonLength    Int             @default(6)
  ruleSet         String?
  eraComparisonId Int?
  eraComparison   EraComparison?  @relation(fields: [eraComparisonId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  SeasonMatchup   SeasonMatchup[]

  @@index([sportId])
  @@index([eraComparisonId])
  @@map("managed_seasons")
}

model SeasonMatchup {
  id                 Int             @id @default(autoincrement())
  managedSeasonId    Int
  managedSeason      ManagedSeason   @relation(fields: [managedSeasonId], references: [id], onDelete: Cascade)
  gameNumber         Int
  opponentTeamName   String
  opponentTeamSeason String
  isCompleted        Boolean         @default(false)
  matchUpResultId    Int?            @unique
  matchUpResult      MatchUpResult?  @relation(fields: [matchUpResultId], references: [id], onDelete: SetNull)
  userTeamScore      Int?
  opponentScore      Int?
  outcomeId          Int?
  outcome            MatchupOutcome? @relation(fields: [outcomeId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([managedSeasonId])
  @@index([matchUpResultId])
  @@index([outcomeId])
  @@map("season_matchups")
}

model MatchupSource {
  id             Int             @id
  name           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  matchUpResults MatchUpResult[]

  @@map("matchup_sources")
}

model GameMode {
  id          Int          @id
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tournaments Tournament[]

  @@map("game_modes")
}

model Tournament {
  id                 Int                  @id @default(autoincrement())
  scenarioName       String               @unique
  shareableSlug      String               @unique
  sport              SportType
  numberOfTeams      Int
  gameModeId         Int                  @default(1)
  gameMode           GameMode             @relation(fields: [gameModeId], references: [id])
  status             String               @default("setup")
  championTeamName   String?
  championTeamSeason String?
  ruleSet            String?
  preview            Json?
  seoSlug            String?              @unique
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  seoContent         String?
  jsonLd             Json?
  robots             String?
  userId             String?
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  teams              TournamentTeam[]
  matchups           TournamentMatchup[]
  comments           Comment[]
  followedBy         FollowedTournament[]

  @@index([shareableSlug])
  @@index([sport])
  @@index([status])
  @@index([userId])
  @@index([gameModeId])
  @@map("tournaments")
}

model TournamentTeam {
  id           Int                 @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamName     String
  teamSeason   String
  seedPosition Int
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  homeMatchups TournamentMatchup[] @relation("HomeTeam")
  awayMatchups TournamentMatchup[] @relation("AwayTeam")
  wonMatchups  TournamentMatchup[] @relation("Winner")

  @@unique([tournamentId, seedPosition])
  @@index([tournamentId])
  @@index([seedPosition])
  @@map("tournament_teams")
}

model TournamentMatchup {
  id                  Int                 @id @default(autoincrement())
  tournamentId        Int
  tournament          Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundNumber         Int
  matchNumber         Int?
  homeTeamId          Int?
  homeTeam            TournamentTeam?     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId          Int?
  awayTeam            TournamentTeam?     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerId            Int?
  winner              TournamentTeam?     @relation("Winner", fields: [winnerId], references: [id])
  matchUpResultId     Int?                @unique
  matchUpResult       MatchUpResult?      @relation(fields: [matchUpResultId], references: [id], onDelete: SetNull)
  matchUpId           Int?                @unique
  matchUp             MatchUp?            @relation(fields: [matchUpId], references: [id], onDelete: SetNull)
  advancesToMatchupId Int?
  advancesToMatchup   TournamentMatchup?  @relation("Advancement", fields: [advancesToMatchupId], references: [id])
  previousMatchups    TournamentMatchup[] @relation("Advancement")
  isCompleted         Boolean             @default(false)
  preview             Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  picks               UserPick[]

  @@index([tournamentId])
  @@index([roundNumber])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([winnerId])
  @@index([matchUpResultId])
  @@index([matchUpId])
  @@index([advancesToMatchupId])
  @@map("tournament_matchups")
}

model UserType {
  id          Int      @id
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("user_types")
}

model UserPick {
  id                  Int                @id @default(autoincrement())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick                String // 'home' or 'away'
  matchUpId           Int?
  matchUp             MatchUp?           @relation(fields: [matchUpId], references: [id], onDelete: Cascade)
  tournamentMatchupId Int?
  tournamentMatchup   TournamentMatchup? @relation(fields: [tournamentMatchupId], references: [id], onDelete: Cascade)
  isCorrect           Boolean?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([userId, matchUpId])
  @@unique([userId, tournamentMatchupId])
  @@index([userId])
  @@index([matchUpId])
  @@index([tournamentMatchupId])
  @@map("user_picks")
}

// Authentication Models
model WalletType {
  id          Int      @id
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  wallets     Wallet[]

  @@map("wallet_types")
}

model User {
  id                  String               @id @default(uuid())
  referralId          String               @unique
  userTypeId          Int                  @default(1)
  userType            UserType             @relation(fields: [userTypeId], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  wallets             Wallet[]
  referralAsReferred  Referral?            @relation("ReferredUser")
  referralsAsReferrer Referral[]           @relation("ReferrerUser")
  tournaments         Tournament[]
  matchUps            MatchUp[]
  profile             UserProfile?
  picks               UserPick[]
  comments            Comment[]
  presaleUsers        PresaleUser[]
  ssoTokens           SsoToken[]
  followedSimulations FollowedSimulation[]
  followedTournaments FollowedTournament[]

  @@index([referralId])
  @@index([userTypeId])
  @@map("users")
}

model FollowedTournament {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  lastViewedAt DateTime?
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId])
  @@index([userId])
  @@index([tournamentId])
  @@map("followed_tournaments")
}

model FollowedSimulation {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchUpId    Int
  matchUp      MatchUp       @relation(fields: [matchUpId], references: [id], onDelete: Cascade)
  simulationId Int
  simulation   MatchUpResult @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  lastViewedAt DateTime?
  createdAt    DateTime      @default(now())

  @@unique([userId, simulationId])
  @@index([userId])
  @@index([matchUpId])
  @@index([simulationId])
  @@map("followed_simulations")
}

model SsoToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("sso_tokens")
}

model UserProfile {
  id              Int      @id @default(autoincrement())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  email           String?  @unique
  username        String?  @unique
  displayName     String?
  bio             String?
  avatar          String?
  isEmailVerified Boolean  @default(false)
  notifications   Boolean  @default(false)
  newsletter      Boolean  @default(false)
  twoFactor       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_profiles")
}

model Referral {
  id             Int      @id @default(autoincrement())
  referredUserId String   @unique
  referredUser   User     @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrerUserId String
  referrerUser   User     @relation("ReferrerUser", fields: [referrerUserId], references: [id], onDelete: Cascade)
  isProcessed    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([referrerUserId])
  @@index([isProcessed])
  @@map("referrals")
}

model Wallet {
  id           Int        @id @default(autoincrement())
  address      String     @unique
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTypeId Int
  walletType   WalletType @relation(fields: [walletTypeId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId])
  @@index([walletTypeId])
  @@index([address])
  @@map("wallets")
}

model Comment {
  id           Int         @id @default(autoincrement())
  content      String
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchUpId    Int?
  matchUp      MatchUp?    @relation(fields: [matchUpId], references: [id], onDelete: Cascade)
  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([matchUpId])
  @@index([tournamentId])
  @@map("comments")
}

model PresaleUser {
  id              String    @id @default(cuid())
  walletAddress   String    @unique
  userId          String? // optional link to User
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  tokensPurchased Float     @default(0)
  claimed         Float     @default(0)
  unclaimed       Float     @default(0)
  amountSpent     Float     @default(0)
  joinDate        DateTime?
  lastActivity    DateTime?

  presaleTxs       PresaleTx[]
  vestingSchedules VestingSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("presale_users")
}

model PresaleTx {
  id           String        @id @default(cuid())
  txHash       String        @unique
  contract     String
  address      String
  tokenAddress String
  type         PresaleTxType @default(Crypto_Payment)
  amount       Float
  stage        Int
  tokens       Float
  timestamp    Int
  usdAmount    Float
  quote        String
  presaleUser  PresaleUser?  @relation(fields: [address], references: [walletAddress])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([address])
  @@index([type])
  @@map("presale_txs")
}

model VestingSchedule {
  id              String      @id @default(cuid())
  walletAddress   String
  scheduleId      Int
  stageId         Int         @default(0)
  totalAmount     Float
  startTime       Int
  cliff           Int
  duration        Int
  releaseInterval Int
  claimed         Float       @default(0)
  contract        String
  presaleUser     PresaleUser @relation(fields: [walletAddress], references: [walletAddress])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([walletAddress, scheduleId, contract])
  @@index([walletAddress])
  @@map("vesting_schedules")
}

model ListenerState {
  id          String    @id @default(cuid())
  contract    String
  blockNumber Int
  hash        String
  logIndex    Int
  processedAt DateTime
  eventId     String    @unique
  type        String
  eventName   String
  blockHash   String
  reorged     Boolean   @default(false)
  reorgedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("listener_states")
}

model FailedEvent {
  id              String    @id @default(cuid())
  eventId         String    @unique
  contract        String
  eventName       String
  blockNumber     Int
  transactionHash String
  logIndex        Int
  error           String
  retryCount      Int       @default(0)
  lastRetryAt     DateTime?
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("failed_events")
}

model Admin {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  address    String   @unique
  superAdmin Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("admins")
}

model AuthNonce {
  walletAddress String   @id
  nonce         String
  createdAt     DateTime @default(now())

  @@map("auth_nonces")
}

model BankTransfer {
  id               String             @id @default(cuid())
  transferId       String             @unique
  walletAddress    String
  amount           Float
  senderName       String
  bankName         String
  transactionRef   String
  paymentRef       String
  submittedDate    DateTime
  status           BankTransferStatus @default(Pending)
  proofUrl         String
  notes            String             @default("")
  verificationNote String?
  verifiedBy       String?
  verifiedAt       DateTime?
  rejectedBy       String?
  rejectedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("bank_transfers")
}

model RecentActivity {
  id            String       @id @default(cuid())
  walletAddress String
  action        String
  activityType  ActivityType
  amount        Float
  usdAmount     Float        @default(0)
  txHash        String?
  metadata      Json?
  timestamp     DateTime
  createdAt     DateTime     @default(now())

  @@index([walletAddress])
  @@index([timestamp])
  @@map("recent_activities")
}

enum PresaleTxType {
  Blockchain
  Wert
  Crypto_Payment
  Bank_Transfer
  Other_Cryptos
  Card_Payment
  Buy
  Claim
}

enum BankTransferStatus {
  Pending
  Verified
  Rejected
}

model PrivateSaleSubmission {
  id               String                      @id @default(cuid())
  submissionId     String                      @unique
  fullName         String
  email            String
  contact          String
  country          String
  walletAddress    String
  amount           Float
  paymentMethod    String
  transactionRef   String
  paymentReference String?
  proofUrl         String
  proofFileName    String?
  notes            String                      @default("")
  status           PrivateSaleSubmissionStatus @default(Pending)
  verificationNote String?
  allocationTxHash String?
  allocatedTokens  String?
  allocatedStageId Int?
  verifiedBy       String?
  verifiedAt       DateTime?
  rejectedBy       String?
  rejectedAt       DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([walletAddress])
  @@index([status])
  @@index([createdAt])
  @@map("private_sale_submissions")
}

enum PrivateSaleSubmissionStatus {
  Pending
  Approved
  Rejected
}

enum ActivityType {
  Buy
  Claim
  Vesting_Created
}
