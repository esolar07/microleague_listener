<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Private Sale Submission Received</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="margin:0;padding:0;background-color:#f0f4ff;font-family:Inter,Arial,Helvetica,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f0f4ff;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" cellspacing="0" cellpadding="0" style="width:100%;max-width:600px;">

          <!-- Blue gradient header -->
          <tr>
            <td style="background:linear-gradient(135deg,#0d0f1a 0%,#1a2040 100%);border-radius:16px 16px 0 0;padding:28px 40px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="vertical-align:middle;">
                    <img src="https://res.cloudinary.com/dp7lq9ug7/image/upload/v1777295629/microleague_coin_nmgjuh.png" alt="MicroLeague" height="30" style="height:30px;display:inline-block;vertical-align:middle;" />
                    <span style="font-size:17px;font-weight:700;color:#ffffff;vertical-align:middle;margin-left:10px;">MicroLeague</span>
                  </td>
                  <td align="right" style="vertical-align:middle;">
                    <span style="font-size:11px;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.35);border-radius:20px;padding:4px 12px;letter-spacing:0.5px;">Private Sale</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- White card body -->
          <tr>
            <td style="background:#ffffff;padding:40px;border-left:1px solid #dde3ef;border-right:1px solid #dde3ef;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0">

                <!-- Check icon -->
                <tr>
                  <td align="center" style="padding-bottom:20px;">
                    <div style="display:inline-block;width:56px;height:56px;background:#e8f0fe;border-radius:50%;text-align:center;line-height:56px;font-size:26px;color:#0055ff;">&#10003;</div>
                  </td>
                </tr>

                <!-- Heading -->
                <tr>
                  <td align="center" style="padding-bottom:10px;">
                    <h1 style="margin:0;font-size:24px;font-weight:700;color:#0f172a;letter-spacing:-0.3px;">Submission Received</h1>
                  </td>
                </tr>

                <!-- Subtext -->
                <tr>
                  <td align="center" style="padding-bottom:32px;">
                    <p style="margin:0;font-size:15px;line-height:1.65;color:#64748b;max-width:440px;">
                      Hi <strong style="color:#0f172a;">{{fullName}}</strong>, your private sale submission has been received and is currently under review. Our team will verify your payment and contact you shortly.
                    </p>
                  </td>
                </tr>

                <!-- Details table -->
                <tr>
                  <td style="padding-bottom:24px;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border:1px solid #dde3ef;border-radius:12px;overflow:hidden;">
                      <tr style="background:#f8faff;">
                        <td style="padding:14px 20px;font-size:13px;color:#64748b;font-weight:500;border-bottom:1px solid #dde3ef;">Submission ID</td>
                        <td align="right" style="padding:14px 20px;font-size:13px;font-weight:600;color:#0f172a;font-family:monospace;border-bottom:1px solid #dde3ef;">{{submissionId}}</td>
                      </tr>
                      <tr style="background:#ffffff;">
                        <td style="padding:14px 20px;font-size:13px;color:#64748b;font-weight:500;border-bottom:1px solid #dde3ef;">Amount</td>
                        <td align="right" style="padding:14px 20px;font-size:13px;font-weight:600;color:#0f172a;border-bottom:1px solid #dde3ef;">${{amount}}</td>
                      </tr>
                      <tr style="background:#f8faff;">
                        <td style="padding:14px 20px;font-size:13px;color:#64748b;font-weight:500;border-bottom:1px solid #dde3ef;">Payment Method</td>
                        <td align="right" style="padding:14px 20px;font-size:13px;font-weight:600;color:#0f172a;border-bottom:1px solid #dde3ef;">{{paymentMethod}}</td>
                      </tr>
                      <tr style="background:#ffffff;">
                        <td style="padding:14px 20px;font-size:13px;color:#64748b;font-weight:500;">Status</td>
                        <td align="right" style="padding:14px 20px;">
                          <span style="display:inline-block;padding:4px 14px;background:#fef3c7;color:#92400e;border-radius:20px;font-size:12px;font-weight:600;">Pending Review</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- What happens next box -->
                <tr>
                  <td style="padding-bottom:32px;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:20px 24px;">
                      <tr>
                        <td>
                          <p style="margin:0 0 6px 0;font-size:14px;font-weight:600;color:#0f172a;">What happens next?</p>
                          <p style="margin:0;font-size:13px;color:#64748b;line-height:1.65;">Our team will review your payment proof and reach out within <strong style="color:#0f172a;">1–2 business days</strong>. Once approved, tokens will be allocated to the wallet you provided.</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Divider -->
                <tr>
                  <td style="padding-bottom:20px;">
                    <div style="height:1px;background-color:#dde3ef;"></div>
                  </td>
                </tr>

                <!-- Footer note -->
                <tr>
                  <td align="center">
                    <p style="margin:0;font-size:12px;color:#94a3b8;line-height:1.6;">
                      This email was sent to <strong style="color:#64748b;">{{email}}</strong>.<br/>If you did not submit this form, please contact our support immediately.
                    </p>
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          <!-- Card footer -->
          <tr>
            <td style="background:#f8faff;border:1px solid #dde3ef;border-top:none;border-radius:0 0 16px 16px;padding:18px 40px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="font-size:12px;color:#94a3b8;">&copy; {{year}} MicroLeague. All rights reserved.</td>
                  <td align="right" style="font-size:12px;">
                    <a href="https://www.microleaguesports.com/privacy" style="color:#0055ff;text-decoration:none;font-weight:500;">Privacy</a>
                    <span style="color:#cbd5e1;margin:0 8px;">·</span>
                    <a href="https://www.microleaguesports.com/terms" style="color:#0055ff;text-decoration:none;font-weight:500;">Terms</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
